# ═══════════════════════════════════════════════════════════════════════════════
#  IoT Healthcare Patient Monitor v5.2 — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/patient_monitor

# ── JWT Auth ──────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
ADMIN_PASSWORD=replace-with-a-strong-admin-password

# ── Data Source ───────────────────────────────────────────────────────────────
# "thingspeak" = real IoT hardware  |  "fake" = simulated data (development)
DATA_SOURCE=fake

# ── ThingSpeak (Real IoT Hardware) ────────────────────────────────────────────
THINGSPEAK_CHANNEL_ID=              # Your ThingSpeak channel ID
THINGSPEAK_READ_API_KEY=            # Your ThingSpeak Read API key
THINGSPEAK_TEMP_UNIT=F              # Temperature unit from sensor: "C" or "F"
THINGSPEAK_STALE_SECONDS=120        # Max age of reading before fallback (seconds)

# ── Redis (for Celery + rate limiting) ────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_REQUIRED=false

# ── SLA ───────────────────────────────────────────────────────────────────────
SLA_THRESHOLD_SECONDS=300

# ── WebSocket ─────────────────────────────────────────────────────────────────
WS_CONNECTION_LIMIT=50
WS_MESSAGES_PER_MINUTE=120
WS_BROADCAST_MODE=event

# ── WhatsApp Notifications (GREEN-API – FREE) ────────────────────────────────
WHATSAPP_ENABLED=true
GREEN_API_ID=your_id_instance
GREEN_API_TOKEN=your_api_token_instance
# WHATSAPP_RECIPIENTS=919876543210,911234567890

# ── Monitoring ────────────────────────────────────────────────────────────────
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ── Alert Storm Protection (v5.2) ────────────────────────────────────────────
MAX_ALERTS_PER_MINUTE=20

# ── Vitals Retention (v5.2) ──────────────────────────────────────────────────
VITALS_RETENTION_DAYS=30

# ── Environment ───────────────────────────────────────────────────────────────
ENVIRONMENT=development
SERVICE_NAME=iot-healthcare
LOG_LEVEL=INFO

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173

# ── Security & Auth (Advanced) ────────────────────────────────────────────────
ADMIN_USERNAME=admin
MAX_SESSIONS_PER_USER=3
ALLOW_MOBILE_IP_VARIATION=false
SUSPICIOUS_IP_WINDOW_SECONDS=300
SUSPICIOUS_REFRESH_WINDOW_SECONDS=60
SUSPICIOUS_REFRESH_BURST=5
COOKIE_SECURE=false
FORGOT_PASSWORD_CODE_TTL_MINUTES=10
REFRESH_TOKEN_EXPIRE_DAYS=7
REFRESH_COOKIE_NAME=refresh_token

# ── Database & Redis Tuning (Advanced) ────────────────────────────────────────
DB_CONNECT_TIMEOUT_SECONDS=5
DB_STATEMENT_TIMEOUT_MS=15000
DB_LOCK_TIMEOUT_MS=3000
DB_IDLE_TX_TIMEOUT_MS=30000
DB_POOL_TIMEOUT_SECONDS=10
REDIS_CONNECT_TIMEOUT=1.0
REDIS_SOCKET_TIMEOUT=1.0
REDIS_RECHECK_INTERVAL_SECONDS=5.0

# ── Application Behavior (Advanced) ───────────────────────────────────────────
WS_USER_CONNECTION_LIMIT=5
WS_MESSAGES_PER_SECOND=10
ALLOW_ADMIN_ALERT_ACK=false
ALLOW_DANGEROUS_RESET=false
WHATSAPP_WEBHOOK_SECRET=
GREEN_API_URL=https://api.green-api.com
