# Required core secrets
POSTGRES_PASSWORD=replace-with-strong-db-password
SECRET_KEY=replace-with-long-random-secret-at-least-32-chars
ADMIN_PASSWORD=replace-with-strong-admin-password
SEED_DB_ON_STARTUP=true

# App runtime
DATA_SOURCE=fake
CORS_ORIGINS=https://yourdomain.com
WHATSAPP_ENABLED=false

# Optional WhatsApp Green API integration
GREEN_API_ID=
GREEN_API_TOKEN=
WHATSAPP_WEBHOOK_SECRET=replace-with-long-random-webhook-secret

# Frontend build/runtime routing
REACT_APP_API_BASE_URL=/api
REACT_APP_WS_BASE_URL=
